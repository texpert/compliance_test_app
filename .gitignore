# macOS
.DS_Store

# IDE metadata
.idea/

# Local environment
.env
.env.*
!.env.example

# Local secrets folder (gitignored)
/secrets/

# Certificates and secrets
/config/certs/*
*.pem
*.key
*.p12
*.pfx
*.csr
*.srl

# Rails runtime artifacts
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/storage/*
!/storage/.keep
/coverage/

# Evidence artifacts that may contain sensitive data
/docs/evidence/

# Ignore key files for decrypting credentials and more.
/config/*.key

# Ignore key files for decrypting credentials and more.
/config/credentials/*.key

