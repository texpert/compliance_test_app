# Salt Edge sandbox environment template (do not commit real secrets)

# Target environment
SE_ENVIRONMENT=sandbox
SE_API_BASE_URL=https://priora.saltedge.com

# TPP registration credentials
SE_CLIENT_ID=your_tpp_client_id
SE_CLIENT_SECRET=your_tpp_client_secret_if_provided

# QSEAL certificate material (use local paths outside repo)
SE_QSEAL_CERT_PATH=$HOME/secrets/saltedge/qseal/qseal_cert.pem
SE_QSEAL_KEY_PATH=$HOME/secrets/saltedge/qseal/qseal_private.key
SE_QSEAL_P12_PATH=$HOME/secrets/saltedge/qseal/qseal_bundle.p12
SE_QSEAL_KEY_PASSPHRASE=change_me
SE_CERT_FINGERPRINT=aa:bb:cc:dd:ee:ff

# Callback/redirect settings (use ngrok-wrapper public URL in local sandbox runs)
SE_CALLBACK_BASE_URL=https://your-ngrok-public-url.example
SE_CALLBACK_PATH=/salt_edge/callback
SE_REDIRECT_URI=https://your-ngrok-public-url.example/salt_edge/callback

# Request behavior
SE_HTTP_TIMEOUT_SECONDS=30
