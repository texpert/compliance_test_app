# Salt Edge sandbox environment template (do not commit real secrets)

SE_API_BASE_URL=https://priora.saltedge.com

# ngrok-wrapper toggles
NGROK_TUNNEL=false
NGROK_CONFIG=$HOME/.ngrok2/ngrok.yml
# Set to true to enable ngrok inspector at http://127.0.0.1:4040
NGROK_INSPECT=false

# Callback base URL — set to ngrok URL when tunnelling, or your server URL otherwise
SE_CALLBACK_BASE_URL=https://your-callback-base-url.example

# Request behavior
SE_HTTP_TIMEOUT_SECONDS=30
