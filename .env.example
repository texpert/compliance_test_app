# Salt Edge sandbox environment template (do not commit real secrets)

# Target environment
SE_ENVIRONMENT=sandbox
SE_API_BASE_URL=https://priora.saltedge.com

# Priora portal app credentials — from connection details tab
# (TPP Verifier docs specify these as the TppVerifierClient credentials)
SE_APP_ID=your_priora_app_id
SE_APP_SECRET=your_priora_app_secret

# TPP registration credentials (pending Milestone 3 portal provisioning)
SE_CLIENT_ID=your_tpp_client_id
SE_CLIENT_SECRET=your_tpp_client_secret_if_provided

# TPP registration payload
SE_TPP_COMPANY_CITY=your_company_city
SE_TPP_COMPANY_ADDRESS=your_company_address
SE_TPP_COMPANY_EMAIL=your_company_email
SE_TPP_COMPANY_NAME=your_company_name
SE_TPP_COMPANY_PHONE_NUMBER=your_company_phone
SE_TPP_COMPANY_ZIP_CODE=your_company_zip
SE_TPP_REPRESENTATIVE_EMAIL=your_representative_email
SE_TPP_REPRESENTATIVE_NAME=your_representative_name
SE_TPP_CERTIFICATE_NAME=your_qseal_certificate_name
SE_TPP_CERTIFICATE_TYPE=qseal

# QSEAL certificate subject values (DN)
SE_QSEAL_SUBJECT_CN=your_legal_entity_common_name
SE_QSEAL_SUBJECT_O=your_legal_entity_organization_name
SE_QSEAL_SUBJECT_C=your_country_code
SE_QSEAL_SUBJECT_ST=your_state_or_region
SE_QSEAL_SUBJECT_ORGANIZATION_IDENTIFIER=your_eidas_org_identifier

# QSEAL certificate material (use local paths outside repo; prefer repo-level git-ignored `./secrets/`)
# Example: ./secrets/qseal/guide_YYYY-MM-DD/client_signed_certifcate.crt
SE_QSEAL_CERT_PATH=./secrets/qseal/guide_YYYY-MM-DD/client_signed_certifcate.crt
SE_QSEAL_KEY_PATH=./secrets/qseal/guide_YYYY-MM-DD/client_private.key
SE_QSEAL_PUBLIC_KEY_PATH=./secrets/qseal/guide_YYYY-MM-DD/client_public.key
SE_QSEAL_P12_PATH=./secrets/qseal/qseal_bundle.p12
SE_QSEAL_KEY_PASSPHRASE=change_me
SE_CERT_FINGERPRINT=aa:bb:cc:dd:ee:ff

# Callback/redirect settings (use ngrok-wrapper public URL in local sandbox runs)
SE_CALLBACK_BASE_URL=https://your-ngrok-public-url.example
SE_CALLBACK_PATH=/callback
SE_REDIRECT_URI=https://your-ngrok-public-url.example/callback

# Request behavior
SE_HTTP_TIMEOUT_SECONDS=30
